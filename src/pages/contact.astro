---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { GlassCard } from '../components/react/ui/GlassCard';
import { StatusIndicator } from '../components/react/ui/StatusIndicator';
---

<DashboardLayout
  title="Contact — Warehaus"
  pageTitle="Contact"
  breadcrumbs={[{ label: 'Dashboard', href: '/' }, { label: 'Contact' }]}
>
  <div class="mx-auto max-w-4xl">
    <section class="mb-12">
      <h1 class="font-display text-4xl font-bold md:text-5xl">Get in Touch</h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted">
        Have a project in mind? We'd love to hear about it.
        Drop us a message and we'll get back to you within 24 hours.
      </p>
    </section>

    <div class="grid gap-8 lg:grid-cols-5">
      <!-- Contact Form -->
      <div class="lg:col-span-3">
        <div class="glass p-6">
          <h2 class="mb-6 font-display text-lg font-semibold">Send a Message</h2>
          <form class="space-y-5" action="#" method="POST">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="name" class="mb-1.5 block text-xs font-medium text-muted">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-lg border border-border bg-surface-elevated px-4 py-2.5 text-sm text-foreground placeholder-muted/50 outline-none transition-colors focus:border-accent"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="mb-1.5 block text-xs font-medium text-muted">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full rounded-lg border border-border bg-surface-elevated px-4 py-2.5 text-sm text-foreground placeholder-muted/50 outline-none transition-colors focus:border-accent"
                  placeholder="you@company.com"
                />
              </div>
            </div>
            <div>
              <label for="subject" class="mb-1.5 block text-xs font-medium text-muted">Subject</label>
              <input
                type="text"
                id="subject"
                name="subject"
                class="w-full rounded-lg border border-border bg-surface-elevated px-4 py-2.5 text-sm text-foreground placeholder-muted/50 outline-none transition-colors focus:border-accent"
                placeholder="Project inquiry"
              />
            </div>
            <div>
              <label for="message" class="mb-1.5 block text-xs font-medium text-muted">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full resize-none rounded-lg border border-border bg-surface-elevated px-4 py-2.5 text-sm text-foreground placeholder-muted/50 outline-none transition-colors focus:border-accent"
                placeholder="Tell us about your project..."
              ></textarea>
            </div>
            <button
              type="submit"
              class="rounded-lg bg-accent px-6 py-2.5 text-sm font-medium text-background transition-colors hover:bg-accent/90"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>

      <!-- Contact Info -->
      <div class="space-y-4 lg:col-span-2">
        <GlassCard client:idle>
          <h3 class="font-display text-sm font-semibold text-accent">Email</h3>
          <a href="mailto:hello@warehaus.studio" class="mt-1 block text-sm text-foreground transition-colors hover:text-accent">
            hello@warehaus.studio
          </a>
        </GlassCard>

        <GlassCard client:idle>
          <h3 class="font-display text-sm font-semibold text-accent">Location</h3>
          <p class="mt-1 text-sm text-foreground">Remote-first, globally distributed</p>
        </GlassCard>

        <GlassCard client:idle>
          <div class="flex items-center justify-between">
            <h3 class="font-display text-sm font-semibold text-accent">Availability</h3>
            <StatusIndicator client:idle status="online" label="Open" size="sm" />
          </div>
          <p class="mt-1 text-sm text-foreground/80">
            Currently accepting new projects for Q2 2026.
          </p>
        </GlassCard>

        <GlassCard client:idle>
          <h3 class="font-display text-sm font-semibold text-accent">Social</h3>
          <div class="mt-2 flex gap-3">
            <a href="#" class="text-sm text-muted transition-colors hover:text-foreground">Twitter</a>
            <a href="#" class="text-sm text-muted transition-colors hover:text-foreground">Dribbble</a>
            <a href="#" class="text-sm text-muted transition-colors hover:text-foreground">GitHub</a>
            <a href="#" class="text-sm text-muted transition-colors hover:text-foreground">LinkedIn</a>
          </div>
        </GlassCard>
      </div>
    </div>
  </div>
</DashboardLayout>
