---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Sidebar from '../components/astro/Sidebar.astro';
import Topbar from '../components/astro/Topbar.astro';

interface Props {
  title?: string;
  pageTitle?: string;
  breadcrumbs?: { label: string; href?: string }[];
  fullBleed?: boolean;
}

const {
  title = 'Warehaus',
  pageTitle,
  breadcrumbs = [],
  fullBleed = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="bg-background text-foreground font-body antialiased">
    <div class="dashboard-grid">
      <Sidebar currentPath={currentPath} transition:persist />

      <div class="dashboard-main">
        <Topbar title={pageTitle} breadcrumbs={breadcrumbs}>
          <slot name="topbar-actions" slot="actions" />
        </Topbar>

        <main
          class:list={[
            'dashboard-content overflow-y-auto',
            fullBleed ? '' : 'p-6',
          ]}
          transition:animate="fade"
        >
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style>
  .dashboard-grid {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    height: 100vh;
    overflow: hidden;
  }

  .dashboard-main {
    display: grid;
    grid-template-rows: var(--topbar-height) 1fr;
    overflow: hidden;
  }

  .dashboard-content {
    overflow-y: auto;
  }

  /* Tablet: collapsed sidebar */
  @media (max-width: 1279px) and (min-width: 768px) {
    .dashboard-grid {
      grid-template-columns: 64px 1fr;
    }
  }

  /* Mobile: no sidebar column */
  @media (max-width: 767px) {
    .dashboard-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
