---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems = [
  { href: '/', label: 'Dashboard', icon: 'grid' },
  { href: '/work', label: 'Work', icon: 'briefcase' },
  { href: '/about', label: 'About', icon: 'user' },
  { href: '/contact', label: 'Contact', icon: 'mail' },
];

function isActive(href: string, current: string) {
  if (href === '/') return current === '/';
  return current.startsWith(href);
}
---

<aside class="fixed left-0 top-0 z-40 flex h-screen w-[var(--sidebar-width)] flex-col border-r border-border bg-surface">
  <!-- Logo -->
  <div class="flex h-[var(--topbar-height)] items-center px-6">
    <a href="/" class="font-display text-lg font-bold tracking-tight text-foreground">
      warehaus
    </a>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3 py-4">
    <ul class="space-y-1">
      {navItems.map((item) => {
        const active = isActive(item.href, currentPath);
        return (
          <li>
            <a
              href={item.href}
              class:list={[
                'group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors',
                active
                  ? 'border-l-2 border-accent bg-accent/5 text-foreground'
                  : 'text-muted hover:bg-surface-elevated hover:text-foreground',
              ]}
            >
              <span class:list={[
                'flex h-5 w-5 items-center justify-center',
                active ? 'text-accent' : 'text-muted group-hover:text-foreground',
              ]}>
                {item.icon === 'grid' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                )}
                {item.icon === 'briefcase' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                )}
                {item.icon === 'user' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                )}
                {item.icon === 'mail' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                )}
              </span>
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>

  <!-- Status indicator -->
  <div class="border-t border-border px-6 py-4">
    <div class="flex items-center gap-2">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-success opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-success"></span>
      </span>
      <span class="text-xs text-muted">Studio Online</span>
    </div>
  </div>
</aside>

<!-- Mobile sidebar (collapsed) -->
<style>
  @media (max-width: 1279px) and (min-width: 768px) {
    aside {
      width: 64px;
    }
    aside a span:last-child,
    aside .border-t span:last-child {
      display: none;
    }
    aside .flex.h-\[var\(--topbar-height\)\] a {
      font-size: 0;
    }
  }
  @media (max-width: 767px) {
    aside {
      transform: translateX(-100%);
      transition: transform 0.3s ease;
    }
    aside.open {
      transform: translateX(0);
    }
  }
</style>
