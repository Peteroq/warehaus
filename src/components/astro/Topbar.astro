---
interface Props {
  title?: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const { title, breadcrumbs = [] } = Astro.props;
---

<header class="flex h-[var(--topbar-height)] items-center justify-between border-b border-border bg-surface/80 px-6 backdrop-blur-sm">
  <div class="flex items-center gap-2">
    {breadcrumbs.length > 0 ? (
      <nav class="flex items-center gap-1.5 text-sm">
        {breadcrumbs.map((crumb, i) => (
          <>
            {i > 0 && <span class="text-border">/</span>}
            {crumb.href ? (
              <a href={crumb.href} class="text-muted transition-colors hover:text-foreground">
                {crumb.label}
              </a>
            ) : (
              <span class="text-foreground">{crumb.label}</span>
            )}
          </>
        ))}
      </nav>
    ) : title ? (
      <h1 class="font-display text-sm font-medium">{title}</h1>
    ) : null}
  </div>

  <div class="flex items-center gap-3">
    <slot name="actions" />
  </div>
</header>
